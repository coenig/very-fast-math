--------------------------------------------------------
-- Sections
--  ==> Segments
--------------------------------------------------------

   DEFINE
      large_number := 10000;

   section_0_segment_1_pos_begin := section_0_segment_0_pos_begin + large_number; -- Helper variable to make below loop simpler.
   section_1_segment_1_pos_begin := section_1_segment_0_pos_begin + large_number; -- Helper variable to make below loop simpler.
   section_2_segment_1_pos_begin := section_2_segment_0_pos_begin + large_number; -- Helper variable to make below loop simpler.
   section_3_segment_1_pos_begin := section_3_segment_0_pos_begin + large_number; -- Helper variable to make below loop simpler.
   


   section_0_lane_0_availability_from_segment_1 := 0;          -- Helper variable to make below loop simpler.
   
   section_0_lane_0_availability_from_segment_0 := case
      section_0_segment_0_min_lane <= 0 & section_0_segment_0_max_lane >= 0 : section_0_lane_0_availability_from_segment_1 + section_0_segment_1_pos_begin - section_0_segment_0_pos_begin;
      TRUE: 0;
   esac;
   
   section_1_lane_0_availability_from_segment_1 := 0;          -- Helper variable to make below loop simpler.
   
   section_1_lane_0_availability_from_segment_0 := case
      section_1_segment_0_min_lane <= 0 & section_1_segment_0_max_lane >= 0 : section_1_lane_0_availability_from_segment_1 + section_1_segment_1_pos_begin - section_1_segment_0_pos_begin;
      TRUE: 0;
   esac;
   
   section_2_lane_0_availability_from_segment_1 := 0;          -- Helper variable to make below loop simpler.
   
   section_2_lane_0_availability_from_segment_0 := case
      section_2_segment_0_min_lane <= 0 & section_2_segment_0_max_lane >= 0 : section_2_lane_0_availability_from_segment_1 + section_2_segment_1_pos_begin - section_2_segment_0_pos_begin;
      TRUE: 0;
   esac;
   
   section_3_lane_0_availability_from_segment_1 := 0;          -- Helper variable to make below loop simpler.
   
   section_3_lane_0_availability_from_segment_0 := case
      section_3_segment_0_min_lane <= 0 & section_3_segment_0_max_lane >= 0 : section_3_lane_0_availability_from_segment_1 + section_3_segment_1_pos_begin - section_3_segment_0_pos_begin;
      TRUE: 0;
   esac;
   
   

   ego.lane_0_availability :=
   case
   ego.on_section = 0:  
         case
            ego.abs_pos >= section_0_segment_0_pos_begin : section_0_lane_0_availability_from_segment_0 + section_0_segment_0_pos_begin - ego.abs_pos;
            TRUE: 0;
         esac;
   ego.on_section = 1:  
         case
            ego.abs_pos >= section_1_segment_0_pos_begin : section_1_lane_0_availability_from_segment_0 + section_1_segment_0_pos_begin - ego.abs_pos;
            TRUE: 0;
         esac;
   ego.on_section = 2:  
         case
            ego.abs_pos >= section_2_segment_0_pos_begin : section_2_lane_0_availability_from_segment_0 + section_2_segment_0_pos_begin - ego.abs_pos;
            TRUE: 0;
         esac;
   ego.on_section = 3:  
         case
            ego.abs_pos >= section_3_segment_0_pos_begin : section_3_lane_0_availability_from_segment_0 + section_3_segment_0_pos_begin - ego.abs_pos;
            TRUE: 0;
         esac;
   
   esac;
   

   INIT 0 = section_0_segment_0_pos_begin;
INIT section_0_segment_0_pos_begin < section_0_end | section_0_segment_0_pos_begin = 0;


INIT section_0_segment_0_max_lane >= section_0_segment_0_min_lane;
INIT section_0_segment_0_min_lane >= 0;
INIT section_0_segment_0_max_lane <= 0;


-- INIT section_0_segment_0_min_lane = 0 & section_0_segment_0_max_lane = 0; -- Make sure we always have a drivable lane at the start. TODO: Make flexible.
INIT section_0_segment_0_max_lane >= section_0_segment_0_min_lane;


INIT 0 = section_1_segment_0_pos_begin;
INIT section_1_segment_0_pos_begin < section_1_end | section_1_segment_0_pos_begin = 0;


INIT section_1_segment_0_max_lane >= section_1_segment_0_min_lane;
INIT section_1_segment_0_min_lane >= 0;
INIT section_1_segment_0_max_lane <= 0;


-- INIT section_1_segment_0_min_lane = 0 & section_1_segment_0_max_lane = 0; -- Make sure we always have a drivable lane at the start. TODO: Make flexible.
INIT section_1_segment_0_max_lane >= section_1_segment_0_min_lane;


INIT 0 = section_2_segment_0_pos_begin;
INIT section_2_segment_0_pos_begin < section_2_end | section_2_segment_0_pos_begin = 0;


INIT section_2_segment_0_max_lane >= section_2_segment_0_min_lane;
INIT section_2_segment_0_min_lane >= 0;
INIT section_2_segment_0_max_lane <= 0;


-- INIT section_2_segment_0_min_lane = 0 & section_2_segment_0_max_lane = 0; -- Make sure we always have a drivable lane at the start. TODO: Make flexible.
INIT section_2_segment_0_max_lane >= section_2_segment_0_min_lane;


INIT 0 = section_3_segment_0_pos_begin;
INIT section_3_segment_0_pos_begin < section_3_end | section_3_segment_0_pos_begin = 0;


INIT section_3_segment_0_max_lane >= section_3_segment_0_min_lane;
INIT section_3_segment_0_min_lane >= 0;
INIT section_3_segment_0_max_lane <= 0;


-- INIT section_3_segment_0_min_lane = 0 & section_3_segment_0_max_lane = 0; -- Make sure we always have a drivable lane at the start. TODO: Make flexible.
INIT section_3_segment_0_max_lane >= section_3_segment_0_min_lane;





--------------------------------------------------------
--  <== EO Segments
--------------------------------------------------------


   FROZENVAR
      section_0.source.x : integer;
         section_0.source.y : integer;
         section_0.angle_raw : 0 .. 3; 

         section_0_segment_0_min_lane : 0 .. 0;
            section_0_segment_0_max_lane : 0 .. 0;
            section_0_segment_0_pos_begin : integer;
         
		 
		 section_0_end : 
		 20 .. 100; -- This is essentially the length of the section.

      FROZENVAR outgoing_connection_0_of_section_0 : -1..3;
      INIT outgoing_connection_0_of_section_0 != 0; -- Do not connect to self.
      INIT outgoing_connection_0_of_section_0 = -1 -> outgoing_connection_1_of_section_0 = -1; -- Reduce topological permutations
      FROZENVAR outgoing_connection_1_of_section_0 : -1..3;
      INIT outgoing_connection_1_of_section_0 != 0; -- Do not connect to self.
       -- Reduce topological permutations
       -- Several elements can be equal, so we have at least 1 and at most 2 outgoing connections.

      

      DEFINE
         section_0.angle := section_0.angle_raw * 90;

         -- Lookup table to speed-up non-linear calculations (sin times 100)
         sin_of_section_0_angle := case
            section_0.angle = 0 : 0;
            section_0.angle = 90 : 100;
            section_0.angle = 180 : 0;
            section_0.angle = 270 : -100;
            
         esac;

         -- Lookup table to speed-up non-linear calculations (cos times 100)
         cos_of_section_0_angle := case
            section_0.angle = 0 : 100;
            section_0.angle = 90 : 0;
            section_0.angle = 180 : -100;
            section_0.angle = 270 : -0;
            
         esac;

         section_0.drain.x := section_0.source.x + (section_0_end * cos_of_section_0_angle) / 100;
         section_0.drain.y := section_0.source.y + (section_0_end * sin_of_section_0_angle) / 100;

         
            FROZENVAR dist_0_of_section_0_to_1 : 10 .. 30;

               INIT outgoing_connection_0_of_section_0 = 1 -> (
                     (section_1.source.x = section_0.drain.x + (dist_0_of_section_0_to_1 * (cos_of_section_0_angle + cos_of_section_1_angle)) / 100)
                     & (section_1.source.y = section_0.drain.y + (dist_0_of_section_0_to_1 * (sin_of_section_0_angle + sin_of_section_1_angle)) / 100)
               );
            FROZENVAR dist_0_of_section_0_to_2 : 10 .. 30;

               INIT outgoing_connection_0_of_section_0 = 2 -> (
                     (section_2.source.x = section_0.drain.x + (dist_0_of_section_0_to_2 * (cos_of_section_0_angle + cos_of_section_2_angle)) / 100)
                     & (section_2.source.y = section_0.drain.y + (dist_0_of_section_0_to_2 * (sin_of_section_0_angle + sin_of_section_2_angle)) / 100)
               );
            FROZENVAR dist_0_of_section_0_to_3 : 10 .. 30;

               INIT outgoing_connection_0_of_section_0 = 3 -> (
                     (section_3.source.x = section_0.drain.x + (dist_0_of_section_0_to_3 * (cos_of_section_0_angle + cos_of_section_3_angle)) / 100)
                     & (section_3.source.y = section_0.drain.y + (dist_0_of_section_0_to_3 * (sin_of_section_0_angle + sin_of_section_3_angle)) / 100)
               );
            
         
            FROZENVAR dist_1_of_section_0_to_1 : 10 .. 30;

               INIT outgoing_connection_1_of_section_0 = 1 -> (
                     (section_1.source.x = section_0.drain.x + (dist_1_of_section_0_to_1 * (cos_of_section_0_angle + cos_of_section_1_angle)) / 100)
                     & (section_1.source.y = section_0.drain.y + (dist_1_of_section_0_to_1 * (sin_of_section_0_angle + sin_of_section_1_angle)) / 100)
               );
            FROZENVAR dist_1_of_section_0_to_2 : 10 .. 30;

               INIT outgoing_connection_1_of_section_0 = 2 -> (
                     (section_2.source.x = section_0.drain.x + (dist_1_of_section_0_to_2 * (cos_of_section_0_angle + cos_of_section_2_angle)) / 100)
                     & (section_2.source.y = section_0.drain.y + (dist_1_of_section_0_to_2 * (sin_of_section_0_angle + sin_of_section_2_angle)) / 100)
               );
            FROZENVAR dist_1_of_section_0_to_3 : 10 .. 30;

               INIT outgoing_connection_1_of_section_0 = 3 -> (
                     (section_3.source.x = section_0.drain.x + (dist_1_of_section_0_to_3 * (cos_of_section_0_angle + cos_of_section_3_angle)) / 100)
                     & (section_3.source.y = section_0.drain.y + (dist_1_of_section_0_to_3 * (sin_of_section_0_angle + sin_of_section_3_angle)) / 100)
               );
            
          -- Several elements can be equal, so we have at least 1 and at most 2 outgoing connections.

         

         
         DEFINE
               angle_from_sec_0_to_sec_1_raw := section_1.angle - section_0.angle;
               angle_from_sec_0_to_sec_1 := case
                  angle_from_sec_0_to_sec_1_raw < 0 : angle_from_sec_0_to_sec_1_raw + 360;
                  angle_from_sec_0_to_sec_1_raw >= 360 : angle_from_sec_0_to_sec_1_raw - 360;
                  TRUE : angle_from_sec_0_to_sec_1_raw;
               esac;
               connection_distance_sec_0_to_sec_1 := case -- TODO: We could have several connections for the same sections with different conn. distances.
                  outgoing_connection_0_of_section_0 = 1 : dist_0_of_section_0_to_1;
                  outgoing_connection_1_of_section_0 = 1 : dist_1_of_section_0_to_1;
                  
                  TRUE : -1;
               esac;

               arclength_from_sec_0_to_sec_1_on_lane_0 := case
                     angle_from_sec_0_to_sec_1 = 0 & connection_distance_sec_0_to_sec_1 = 10 : 20;
                        angle_from_sec_0_to_sec_1 = 0 & connection_distance_sec_0_to_sec_1 = 11 : 22;
                        angle_from_sec_0_to_sec_1 = 0 & connection_distance_sec_0_to_sec_1 = 12 : 24;
                        angle_from_sec_0_to_sec_1 = 0 & connection_distance_sec_0_to_sec_1 = 13 : 26;
                        angle_from_sec_0_to_sec_1 = 0 & connection_distance_sec_0_to_sec_1 = 14 : 28;
                        angle_from_sec_0_to_sec_1 = 0 & connection_distance_sec_0_to_sec_1 = 15 : 30;
                        angle_from_sec_0_to_sec_1 = 0 & connection_distance_sec_0_to_sec_1 = 16 : 32;
                        angle_from_sec_0_to_sec_1 = 0 & connection_distance_sec_0_to_sec_1 = 17 : 34;
                        angle_from_sec_0_to_sec_1 = 0 & connection_distance_sec_0_to_sec_1 = 18 : 36;
                        angle_from_sec_0_to_sec_1 = 0 & connection_distance_sec_0_to_sec_1 = 19 : 38;
                        angle_from_sec_0_to_sec_1 = 0 & connection_distance_sec_0_to_sec_1 = 20 : 40;
                        angle_from_sec_0_to_sec_1 = 0 & connection_distance_sec_0_to_sec_1 = 21 : 42;
                        angle_from_sec_0_to_sec_1 = 0 & connection_distance_sec_0_to_sec_1 = 22 : 44;
                        angle_from_sec_0_to_sec_1 = 0 & connection_distance_sec_0_to_sec_1 = 23 : 46;
                        angle_from_sec_0_to_sec_1 = 0 & connection_distance_sec_0_to_sec_1 = 24 : 48;
