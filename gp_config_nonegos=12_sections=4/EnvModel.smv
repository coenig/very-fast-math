                        angle_from_sec_0_to_sec_1 = 180 & connection_distance_sec_0_to_sec_1 = 16 : 0;
                        angle_from_sec_0_to_sec_1 = 180 & connection_distance_sec_0_to_sec_1 = 17 : 0;
                        angle_from_sec_0_to_sec_1 = 180 & connection_distance_sec_0_to_sec_1 = 18 : 0;
