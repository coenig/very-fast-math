                        angle_from_sec_0_to_sec_1 = 180 & connection_distance_sec_0_to_sec_1 = 29 : 0;
                        angle_from_sec_0_to_sec_1 = 180 & connection_distance_sec_0_to_sec_1 = 30 : 0;
                        
                     angle_from_sec_0_to_sec_1 = 270 & connection_distance_sec_0_to_sec_1 = 10 : 15;
                        angle_from_sec_0_to_sec_1 = 270 & connection_distance_sec_0_to_sec_1 = 11 : 17;
                        angle_from_sec_0_to_sec_1 = 270 & connection_distance_sec_0_to_sec_1 = 12 : 18;
                        angle_from_sec_0_to_sec_1 = 270 & connection_distance_sec_0_to_sec_1 = 13 : 20;
                        angle_from_sec_0_to_sec_1 = 270 & connection_distance_sec_0_to_sec_1 = 14 : 22;
                        angle_from_sec_0_to_sec_1 = 270 & connection_distance_sec_0_to_sec_1 = 15 : 23;
                        angle_from_sec_0_to_sec_1 = 270 & connection_distance_sec_0_to_sec_1 = 16 : 25;
                        angle_from_sec_0_to_sec_1 = 270 & connection_distance_sec_0_to_sec_1 = 17 : 26;
                        angle_from_sec_0_to_sec_1 = 270 & connection_distance_sec_0_to_sec_1 = 18 : 28;
                        angle_from_sec_0_to_sec_1 = 270 & connection_distance_sec_0_to_sec_1 = 19 : 29;
                        angle_from_sec_0_to_sec_1 = 270 & connection_distance_sec_0_to_sec_1 = 20 : 31;
                        angle_from_sec_0_to_sec_1 = 270 & connection_distance_sec_0_to_sec_1 = 21 : 32;
                        angle_from_sec_0_to_sec_1 = 270 & connection_distance_sec_0_to_sec_1 = 22 : 34;
                        angle_from_sec_0_to_sec_1 = 270 & connection_distance_sec_0_to_sec_1 = 23 : 35;
                        angle_from_sec_0_to_sec_1 = 270 & connection_distance_sec_0_to_sec_1 = 24 : 37;
                        angle_from_sec_0_to_sec_1 = 270 & connection_distance_sec_0_to_sec_1 = 25 : 38;
                        angle_from_sec_0_to_sec_1 = 270 & connection_distance_sec_0_to_sec_1 = 26 : 40;
                        angle_from_sec_0_to_sec_1 = 270 & connection_distance_sec_0_to_sec_1 = 27 : 42;
                        angle_from_sec_0_to_sec_1 = 270 & connection_distance_sec_0_to_sec_1 = 28 : 43;
                        angle_from_sec_0_to_sec_1 = 270 & connection_distance_sec_0_to_sec_1 = 29 : 45;
                        angle_from_sec_0_to_sec_1 = 270 & connection_distance_sec_0_to_sec_1 = 30 : 46;
                        
                     
                     TRUE : -1;
                  esac;
               
         DEFINE
               angle_from_sec_0_to_sec_2_raw := section_2.angle - section_0.angle;
               angle_from_sec_0_to_sec_2 := case
                  angle_from_sec_0_to_sec_2_raw < 0 : angle_from_sec_0_to_sec_2_raw + 360;
                  angle_from_sec_0_to_sec_2_raw >= 360 : angle_from_sec_0_to_sec_2_raw - 360;
                  TRUE : angle_from_sec_0_to_sec_2_raw;
               esac;
               connection_distance_sec_0_to_sec_2 := case -- TODO: We could have several connections for the same sections with different conn. distances.
                  outgoing_connection_0_of_section_0 = 2 : dist_0_of_section_0_to_2;
                  outgoing_connection_1_of_section_0 = 2 : dist_1_of_section_0_to_2;
                  
                  TRUE : -1;
               esac;

