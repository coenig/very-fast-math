-- Prohibit lane changes for non-egos as long as ego is changing lanes
--------------------------------------------------------
TRANS (next(ego.left_of_veh_1_lane)  & next(veh___619___.rel_pos) >= -veh_length & next(veh___619___.rel_pos) <= veh_length) -> !veh___619___.lane_move_up;
TRANS (next(ego.right_of_veh_1_lane) & next(veh___619___.rel_pos) >= -veh_length & next(veh___619___.rel_pos) <= veh_length) -> !veh___619___.lane_move_down;
TRANS (next(ego.left_of_veh_2_lane)  & next(veh___629___.rel_pos) >= -veh_length & next(veh___629___.rel_pos) <= veh_length) -> !veh___629___.lane_move_up;
