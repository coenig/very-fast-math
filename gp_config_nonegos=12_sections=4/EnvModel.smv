                        angle_from_sec_2_to_sec_3 = 90 & connection_distance_sec_2_to_sec_3 = 23 : 35;
                        angle_from_sec_2_to_sec_3 = 90 & connection_distance_sec_2_to_sec_3 = 24 : 37;
