                        angle_from_sec_2_to_sec_0 = 0 & connection_distance_sec_2_to_sec_0 = 30 : 60;
                        
                     angle_from_sec_2_to_sec_0 = 90 & connection_distance_sec_2_to_sec_0 = 10 : 15;
                        angle_from_sec_2_to_sec_0 = 90 & connection_distance_sec_2_to_sec_0 = 11 : 17;
                        angle_from_sec_2_to_sec_0 = 90 & connection_distance_sec_2_to_sec_0 = 12 : 18;
