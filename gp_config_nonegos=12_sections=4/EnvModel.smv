            section_2_segment_0_max_lane : 0 .. 0;
            section_2_segment_0_pos_begin : integer;
         
		 
		 section_2_end : 
		 20 .. 100; -- This is essentially the length of the section.

      FROZENVAR outgoing_connection_0_of_section_2 : -1..3;
      INIT outgoing_connection_0_of_section_2 != 2; -- Do not connect to self.
      INIT outgoing_connection_0_of_section_2 = -1 -> outgoing_connection_1_of_section_2 = -1; -- Reduce topological permutations
      FROZENVAR outgoing_connection_1_of_section_2 : -1..3;
      INIT outgoing_connection_1_of_section_2 != 2; -- Do not connect to self.
       -- Reduce topological permutations
       -- Several elements can be equal, so we have at least 1 and at most 2 outgoing connections.

      

      DEFINE
         section_2.angle := section_2.angle_raw * 90;

         -- Lookup table to speed-up non-linear calculations (sin times 100)
         sin_of_section_2_angle := case
            section_2.angle = 0 : 0;
            section_2.angle = 90 : 100;
            section_2.angle = 180 : 0;
            section_2.angle = 270 : -100;
            
         esac;

         -- Lookup table to speed-up non-linear calculations (cos times 100)
         cos_of_section_2_angle := case
            section_2.angle = 0 : 100;
            section_2.angle = 90 : 0;
            section_2.angle = 180 : -100;
            section_2.angle = 270 : -0;
            
         esac;

         section_2.drain.x := section_2.source.x + (section_2_end * cos_of_section_2_angle) / 100;
         section_2.drain.y := section_2.source.y + (section_2_end * sin_of_section_2_angle) / 100;

         FROZENVAR dist_0_of_section_2_to_0 : 10 .. 30;

               INIT outgoing_connection_0_of_section_2 = 0 -> (
                     (section_0.source.x = section_2.drain.x + (dist_0_of_section_2_to_0 * (cos_of_section_2_angle + cos_of_section_0_angle)) / 100)
                     & (section_0.source.y = section_2.drain.y + (dist_0_of_section_2_to_0 * (sin_of_section_2_angle + sin_of_section_0_angle)) / 100)
               );
            FROZENVAR dist_0_of_section_2_to_1 : 10 .. 30;

               INIT outgoing_connection_0_of_section_2 = 1 -> (
                     (section_1.source.x = section_2.drain.x + (dist_0_of_section_2_to_1 * (cos_of_section_2_angle + cos_of_section_1_angle)) / 100)
                     & (section_1.source.y = section_2.drain.y + (dist_0_of_section_2_to_1 * (sin_of_section_2_angle + sin_of_section_1_angle)) / 100)
               );
            
            FROZENVAR dist_0_of_section_2_to_3 : 10 .. 30;

               INIT outgoing_connection_0_of_section_2 = 3 -> (
                     (section_3.source.x = section_2.drain.x + (dist_0_of_section_2_to_3 * (cos_of_section_2_angle + cos_of_section_3_angle)) / 100)
                     & (section_3.source.y = section_2.drain.y + (dist_0_of_section_2_to_3 * (sin_of_section_2_angle + sin_of_section_3_angle)) / 100)
               );
            
         FROZENVAR dist_1_of_section_2_to_0 : 10 .. 30;

               INIT outgoing_connection_1_of_section_2 = 0 -> (
                     (section_0.source.x = section_2.drain.x + (dist_1_of_section_2_to_0 * (cos_of_section_2_angle + cos_of_section_0_angle)) / 100)
                     & (section_0.source.y = section_2.drain.y + (dist_1_of_section_2_to_0 * (sin_of_section_2_angle + sin_of_section_0_angle)) / 100)
               );
            FROZENVAR dist_1_of_section_2_to_1 : 10 .. 30;

               INIT outgoing_connection_1_of_section_2 = 1 -> (
                     (section_1.source.x = section_2.drain.x + (dist_1_of_section_2_to_1 * (cos_of_section_2_angle + cos_of_section_1_angle)) / 100)
                     & (section_1.source.y = section_2.drain.y + (dist_1_of_section_2_to_1 * (sin_of_section_2_angle + sin_of_section_1_angle)) / 100)
               );
            
            FROZENVAR dist_1_of_section_2_to_3 : 10 .. 30;

               INIT outgoing_connection_1_of_section_2 = 3 -> (
                     (section_3.source.x = section_2.drain.x + (dist_1_of_section_2_to_3 * (cos_of_section_2_angle + cos_of_section_3_angle)) / 100)
                     & (section_3.source.y = section_2.drain.y + (dist_1_of_section_2_to_3 * (sin_of_section_2_angle + sin_of_section_3_angle)) / 100)
               );
            
          -- Several elements can be equal, so we have at least 1 and at most 2 outgoing connections.

         INIT ( max( abs( section_2.source.x - section_0.source.x ), abs( section_2.source.y - section_0.source.y ) ) )  
               >= 5; -- Use only farther away coordinate as lower bound.
            INIT ( max( abs( section_2.source.x - section_0.drain.x ), abs( section_2.source.y - section_0.drain.y ) ) )  
               >= 5; -- Use only farther away coordinate as lower bound.
            INIT ( max( abs( section_2.drain.x - section_0.source.x ), abs( section_2.drain.y - section_0.source.y ) ) )  
               >= 5; -- Use only farther away coordinate as lower bound.
         INIT ( max( abs( section_2.source.x - section_1.source.x ), abs( section_2.source.y - section_1.source.y ) ) )  
               >= 5; -- Use only farther away coordinate as lower bound.
            INIT ( max( abs( section_2.source.x - section_1.drain.x ), abs( section_2.source.y - section_1.drain.y ) ) )  
               >= 5; -- Use only farther away coordinate as lower bound.
            INIT ( max( abs( section_2.drain.x - section_1.source.x ), abs( section_2.drain.y - section_1.source.y ) ) )  
               >= 5; -- Use only farther away coordinate as lower bound.
         

         DEFINE
               angle_from_sec_2_to_sec_0_raw := section_0.angle - section_2.angle;
               angle_from_sec_2_to_sec_0 := case
                  angle_from_sec_2_to_sec_0_raw < 0 : angle_from_sec_2_to_sec_0_raw + 360;
                  angle_from_sec_2_to_sec_0_raw >= 360 : angle_from_sec_2_to_sec_0_raw - 360;
                  TRUE : angle_from_sec_2_to_sec_0_raw;
               esac;
               connection_distance_sec_2_to_sec_0 := case -- TODO: We could have several connections for the same sections with different conn. distances.
                  outgoing_connection_0_of_section_2 = 0 : dist_0_of_section_2_to_0;
                  outgoing_connection_1_of_section_2 = 0 : dist_1_of_section_2_to_0;
                  
                  TRUE : -1;
               esac;

               arclength_from_sec_2_to_sec_0_on_lane_0 := case
