                        angle_from_sec_0_to_sec_1 = 0 & connection_distance_sec_0_to_sec_1 = 30 : 60;
                        
                     angle_from_sec_0_to_sec_1 = 90 & connection_distance_sec_0_to_sec_1 = 10 : 15;
                        angle_from_sec_0_to_sec_1 = 90 & connection_distance_sec_0_to_sec_1 = 11 : 17;
                        angle_from_sec_0_to_sec_1 = 90 & connection_distance_sec_0_to_sec_1 = 12 : 18;
                        angle_from_sec_0_to_sec_1 = 90 & connection_distance_sec_0_to_sec_1 = 13 : 20;
                        angle_from_sec_0_to_sec_1 = 90 & connection_distance_sec_0_to_sec_1 = 14 : 22;
                        angle_from_sec_0_to_sec_1 = 90 & connection_distance_sec_0_to_sec_1 = 15 : 23;
                        angle_from_sec_0_to_sec_1 = 90 & connection_distance_sec_0_to_sec_1 = 16 : 25;
                        angle_from_sec_0_to_sec_1 = 90 & connection_distance_sec_0_to_sec_1 = 17 : 26;
                        angle_from_sec_0_to_sec_1 = 90 & connection_distance_sec_0_to_sec_1 = 18 : 28;
                        angle_from_sec_0_to_sec_1 = 90 & connection_distance_sec_0_to_sec_1 = 19 : 29;
                        angle_from_sec_0_to_sec_1 = 90 & connection_distance_sec_0_to_sec_1 = 20 : 31;
                        angle_from_sec_0_to_sec_1 = 90 & connection_distance_sec_0_to_sec_1 = 21 : 32;
                        angle_from_sec_0_to_sec_1 = 90 & connection_distance_sec_0_to_sec_1 = 22 : 34;
                        angle_from_sec_0_to_sec_1 = 90 & connection_distance_sec_0_to_sec_1 = 23 : 35;
                        angle_from_sec_0_to_sec_1 = 90 & connection_distance_sec_0_to_sec_1 = 24 : 37;
                        angle_from_sec_0_to_sec_1 = 90 & connection_distance_sec_0_to_sec_1 = 25 : 38;
                        angle_from_sec_0_to_sec_1 = 90 & connection_distance_sec_0_to_sec_1 = 26 : 40;
                        angle_from_sec_0_to_sec_1 = 90 & connection_distance_sec_0_to_sec_1 = 27 : 42;
                        angle_from_sec_0_to_sec_1 = 90 & connection_distance_sec_0_to_sec_1 = 28 : 43;
                        angle_from_sec_0_to_sec_1 = 90 & connection_distance_sec_0_to_sec_1 = 29 : 45;
                        angle_from_sec_0_to_sec_1 = 90 & connection_distance_sec_0_to_sec_1 = 30 : 46;
                        
                     angle_from_sec_0_to_sec_1 = 180 & connection_distance_sec_0_to_sec_1 = 10 : 0;
                        angle_from_sec_0_to_sec_1 = 180 & connection_distance_sec_0_to_sec_1 = 11 : 0;
                        angle_from_sec_0_to_sec_1 = 180 & connection_distance_sec_0_to_sec_1 = 12 : 0;
                        angle_from_sec_0_to_sec_1 = 180 & connection_distance_sec_0_to_sec_1 = 13 : 0;
