                        angle_from_sec_2_to_sec_3 = 270 & connection_distance_sec_2_to_sec_3 = 17 : 26;
                        angle_from_sec_2_to_sec_3 = 270 & connection_distance_sec_2_to_sec_3 = 18 : 28;
                        angle_from_sec_2_to_sec_3 = 270 & connection_distance_sec_2_to_sec_3 = 19 : 29;
                        angle_from_sec_2_to_sec_3 = 270 & connection_distance_sec_2_to_sec_3 = 20 : 31;
                        angle_from_sec_2_to_sec_3 = 270 & connection_distance_sec_2_to_sec_3 = 21 : 32;
                        angle_from_sec_2_to_sec_3 = 270 & connection_distance_sec_2_to_sec_3 = 22 : 34;
                        angle_from_sec_2_to_sec_3 = 270 & connection_distance_sec_2_to_sec_3 = 23 : 35;
                        angle_from_sec_2_to_sec_3 = 270 & connection_distance_sec_2_to_sec_3 = 24 : 37;
                        angle_from_sec_2_to_sec_3 = 270 & connection_distance_sec_2_to_sec_3 = 25 : 38;
                        angle_from_sec_2_to_sec_3 = 270 & connection_distance_sec_2_to_sec_3 = 26 : 40;
                        angle_from_sec_2_to_sec_3 = 270 & connection_distance_sec_2_to_sec_3 = 27 : 42;
                        angle_from_sec_2_to_sec_3 = 270 & connection_distance_sec_2_to_sec_3 = 28 : 43;
                        angle_from_sec_2_to_sec_3 = 270 & connection_distance_sec_2_to_sec_3 = 29 : 45;
                        angle_from_sec_2_to_sec_3 = 270 & connection_distance_sec_2_to_sec_3 = 30 : 46;
                        
                     
                     TRUE : -1;
                  esac;
               
          

       

   FROZENVAR
      section_3.source.x : integer;
         section_3.source.y : integer;
         section_3.angle_raw : 0 .. 3; 

         section_3_segment_0_min_lane : 0 .. 0;
            section_3_segment_0_max_lane : 0 .. 0;
            section_3_segment_0_pos_begin : integer;
         
		 
		 section_3_end : 
		 20 .. 100; -- This is essentially the length of the section.

      FROZENVAR outgoing_connection_0_of_section_3 : -1..3;
      INIT outgoing_connection_0_of_section_3 != 3; -- Do not connect to self.
      INIT outgoing_connection_0_of_section_3 = -1 -> outgoing_connection_1_of_section_3 = -1; -- Reduce topological permutations
      FROZENVAR outgoing_connection_1_of_section_3 : -1..3;
      INIT outgoing_connection_1_of_section_3 != 3; -- Do not connect to self.
       -- Reduce topological permutations
       -- Several elements can be equal, so we have at least 1 and at most 2 outgoing connections.

      

      DEFINE
         section_3.angle := section_3.angle_raw * 90;

         -- Lookup table to speed-up non-linear calculations (sin times 100)
         sin_of_section_3_angle := case
            section_3.angle = 0 : 0;
            section_3.angle = 90 : 100;
            section_3.angle = 180 : 0;
            section_3.angle = 270 : -100;
            
         esac;

         -- Lookup table to speed-up non-linear calculations (cos times 100)
         cos_of_section_3_angle := case
            section_3.angle = 0 : 100;
            section_3.angle = 90 : 0;
            section_3.angle = 180 : -100;
            section_3.angle = 270 : -0;
            
         esac;

         section_3.drain.x := section_3.source.x + (section_3_end * cos_of_section_3_angle) / 100;
         section_3.drain.y := section_3.source.y + (section_3_end * sin_of_section_3_angle) / 100;

         FROZENVAR dist_0_of_section_3_to_0 : 10 .. 30;

               INIT outgoing_connection_0_of_section_3 = 0 -> (
                     (section_0.source.x = section_3.drain.x + (dist_0_of_section_3_to_0 * (cos_of_section_3_angle + cos_of_section_0_angle)) / 100)
                     & (section_0.source.y = section_3.drain.y + (dist_0_of_section_3_to_0 * (sin_of_section_3_angle + sin_of_section_0_angle)) / 100)
               );
            FROZENVAR dist_0_of_section_3_to_1 : 10 .. 30;

               INIT outgoing_connection_0_of_section_3 = 1 -> (
                     (section_1.source.x = section_3.drain.x + (dist_0_of_section_3_to_1 * (cos_of_section_3_angle + cos_of_section_1_angle)) / 100)
                     & (section_1.source.y = section_3.drain.y + (dist_0_of_section_3_to_1 * (sin_of_section_3_angle + sin_of_section_1_angle)) / 100)
               );
            FROZENVAR dist_0_of_section_3_to_2 : 10 .. 30;

               INIT outgoing_connection_0_of_section_3 = 2 -> (
                     (section_2.source.x = section_3.drain.x + (dist_0_of_section_3_to_2 * (cos_of_section_3_angle + cos_of_section_2_angle)) / 100)
                     & (section_2.source.y = section_3.drain.y + (dist_0_of_section_3_to_2 * (sin_of_section_3_angle + sin_of_section_2_angle)) / 100)
               );
            
            
         FROZENVAR dist_1_of_section_3_to_0 : 10 .. 30;

               INIT outgoing_connection_1_of_section_3 = 0 -> (
                     (section_0.source.x = section_3.drain.x + (dist_1_of_section_3_to_0 * (cos_of_section_3_angle + cos_of_section_0_angle)) / 100)
                     & (section_0.source.y = section_3.drain.y + (dist_1_of_section_3_to_0 * (sin_of_section_3_angle + sin_of_section_0_angle)) / 100)
               );
            FROZENVAR dist_1_of_section_3_to_1 : 10 .. 30;

               INIT outgoing_connection_1_of_section_3 = 1 -> (
                     (section_1.source.x = section_3.drain.x + (dist_1_of_section_3_to_1 * (cos_of_section_3_angle + cos_of_section_1_angle)) / 100)
                     & (section_1.source.y = section_3.drain.y + (dist_1_of_section_3_to_1 * (sin_of_section_3_angle + sin_of_section_1_angle)) / 100)
               );
            FROZENVAR dist_1_of_section_3_to_2 : 10 .. 30;

               INIT outgoing_connection_1_of_section_3 = 2 -> (
                     (section_2.source.x = section_3.drain.x + (dist_1_of_section_3_to_2 * (cos_of_section_3_angle + cos_of_section_2_angle)) / 100)
                     & (section_2.source.y = section_3.drain.y + (dist_1_of_section_3_to_2 * (sin_of_section_3_angle + sin_of_section_2_angle)) / 100)
               );
            
            
          -- Several elements can be equal, so we have at least 1 and at most 2 outgoing connections.

         INIT ( max( abs( section_3.source.x - section_0.source.x ), abs( section_3.source.y - section_0.source.y ) ) )  
               >= 5; -- Use only farther away coordinate as lower bound.
            INIT ( max( abs( section_3.source.x - section_0.drain.x ), abs( section_3.source.y - section_0.drain.y ) ) )  
               >= 5; -- Use only farther away coordinate as lower bound.
            INIT ( max( abs( section_3.drain.x - section_0.source.x ), abs( section_3.drain.y - section_0.source.y ) ) )  
               >= 5; -- Use only farther away coordinate as lower bound.
         INIT ( max( abs( section_3.source.x - section_1.source.x ), abs( section_3.source.y - section_1.source.y ) ) )  
               >= 5; -- Use only farther away coordinate as lower bound.
            INIT ( max( abs( section_3.source.x - section_1.drain.x ), abs( section_3.source.y - section_1.drain.y ) ) )  
               >= 5; -- Use only farther away coordinate as lower bound.
            INIT ( max( abs( section_3.drain.x - section_1.source.x ), abs( section_3.drain.y - section_1.source.y ) ) )  
               >= 5; -- Use only farther away coordinate as lower bound.
         INIT ( max( abs( section_3.source.x - section_2.source.x ), abs( section_3.source.y - section_2.source.y ) ) )  
               >= 5; -- Use only farther away coordinate as lower bound.
            INIT ( max( abs( section_3.source.x - section_2.drain.x ), abs( section_3.source.y - section_2.drain.y ) ) )  
               >= 5; -- Use only farther away coordinate as lower bound.
            INIT ( max( abs( section_3.drain.x - section_2.source.x ), abs( section_3.drain.y - section_2.source.y ) ) )  
               >= 5; -- Use only farther away coordinate as lower bound.
         

         DEFINE
               angle_from_sec_3_to_sec_0_raw := section_0.angle - section_3.angle;
               angle_from_sec_3_to_sec_0 := case
                  angle_from_sec_3_to_sec_0_raw < 0 : angle_from_sec_3_to_sec_0_raw + 360;
                  angle_from_sec_3_to_sec_0_raw >= 360 : angle_from_sec_3_to_sec_0_raw - 360;
                  TRUE : angle_from_sec_3_to_sec_0_raw;
               esac;
               connection_distance_sec_3_to_sec_0 := case -- TODO: We could have several connections for the same sections with different conn. distances.
                  outgoing_connection_0_of_section_3 = 0 : dist_0_of_section_3_to_0;
                  outgoing_connection_1_of_section_3 = 0 : dist_1_of_section_3_to_0;
                  
                  TRUE : -1;
               esac;

               arclength_from_sec_3_to_sec_0_on_lane_0 := case
                     angle_from_sec_3_to_sec_0 = 0 & connection_distance_sec_3_to_sec_0 = 10 : 20;
                        angle_from_sec_3_to_sec_0 = 0 & connection_distance_sec_3_to_sec_0 = 11 : 22;
                        angle_from_sec_3_to_sec_0 = 0 & connection_distance_sec_3_to_sec_0 = 12 : 24;
                        angle_from_sec_3_to_sec_0 = 0 & connection_distance_sec_3_to_sec_0 = 13 : 26;
                        angle_from_sec_3_to_sec_0 = 0 & connection_distance_sec_3_to_sec_0 = 14 : 28;
                        angle_from_sec_3_to_sec_0 = 0 & connection_distance_sec_3_to_sec_0 = 15 : 30;
                        angle_from_sec_3_to_sec_0 = 0 & connection_distance_sec_3_to_sec_0 = 16 : 32;
                        angle_from_sec_3_to_sec_0 = 0 & connection_distance_sec_3_to_sec_0 = 17 : 34;
                        angle_from_sec_3_to_sec_0 = 0 & connection_distance_sec_3_to_sec_0 = 18 : 36;
                        angle_from_sec_3_to_sec_0 = 0 & connection_distance_sec_3_to_sec_0 = 19 : 38;
                        angle_from_sec_3_to_sec_0 = 0 & connection_distance_sec_3_to_sec_0 = 20 : 40;
                        angle_from_sec_3_to_sec_0 = 0 & connection_distance_sec_3_to_sec_0 = 21 : 42;
                        angle_from_sec_3_to_sec_0 = 0 & connection_distance_sec_3_to_sec_0 = 22 : 44;
                        angle_from_sec_3_to_sec_0 = 0 & connection_distance_sec_3_to_sec_0 = 23 : 46;
                        angle_from_sec_3_to_sec_0 = 0 & connection_distance_sec_3_to_sec_0 = 24 : 48;
                        angle_from_sec_3_to_sec_0 = 0 & connection_distance_sec_3_to_sec_0 = 25 : 50;
                        angle_from_sec_3_to_sec_0 = 0 & connection_distance_sec_3_to_sec_0 = 26 : 52;
                        angle_from_sec_3_to_sec_0 = 0 & connection_distance_sec_3_to_sec_0 = 27 : 54;
                        angle_from_sec_3_to_sec_0 = 0 & connection_distance_sec_3_to_sec_0 = 28 : 56;
                        angle_from_sec_3_to_sec_0 = 0 & connection_distance_sec_3_to_sec_0 = 29 : 58;
                        angle_from_sec_3_to_sec_0 = 0 & connection_distance_sec_3_to_sec_0 = 30 : 60;
                        
                     angle_from_sec_3_to_sec_0 = 90 & connection_distance_sec_3_to_sec_0 = 10 : 15;
                        angle_from_sec_3_to_sec_0 = 90 & connection_distance_sec_3_to_sec_0 = 11 : 17;
                        angle_from_sec_3_to_sec_0 = 90 & connection_distance_sec_3_to_sec_0 = 12 : 18;
                        angle_from_sec_3_to_sec_0 = 90 & connection_distance_sec_3_to_sec_0 = 13 : 20;
                        angle_from_sec_3_to_sec_0 = 90 & connection_distance_sec_3_to_sec_0 = 14 : 22;
                        angle_from_sec_3_to_sec_0 = 90 & connection_distance_sec_3_to_sec_0 = 15 : 23;
                        angle_from_sec_3_to_sec_0 = 90 & connection_distance_sec_3_to_sec_0 = 16 : 25;
                        angle_from_sec_3_to_sec_0 = 90 & connection_distance_sec_3_to_sec_0 = 17 : 26;
                        angle_from_sec_3_to_sec_0 = 90 & connection_distance_sec_3_to_sec_0 = 18 : 28;
                        angle_from_sec_3_to_sec_0 = 90 & connection_distance_sec_3_to_sec_0 = 19 : 29;
                        angle_from_sec_3_to_sec_0 = 90 & connection_distance_sec_3_to_sec_0 = 20 : 31;
                        angle_from_sec_3_to_sec_0 = 90 & connection_distance_sec_3_to_sec_0 = 21 : 32;
                        angle_from_sec_3_to_sec_0 = 90 & connection_distance_sec_3_to_sec_0 = 22 : 34;
                        angle_from_sec_3_to_sec_0 = 90 & connection_distance_sec_3_to_sec_0 = 23 : 35;
                        angle_from_sec_3_to_sec_0 = 90 & connection_distance_sec_3_to_sec_0 = 24 : 37;
                        angle_from_sec_3_to_sec_0 = 90 & connection_distance_sec_3_to_sec_0 = 25 : 38;
