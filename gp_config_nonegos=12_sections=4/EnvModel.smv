                     angle_from_sec_2_to_sec_3 = 180 & connection_distance_sec_2_to_sec_3 = 10 : 0;
                        angle_from_sec_2_to_sec_3 = 180 & connection_distance_sec_2_to_sec_3 = 11 : 0;
                        angle_from_sec_2_to_sec_3 = 180 & connection_distance_sec_2_to_sec_3 = 12 : 0;
