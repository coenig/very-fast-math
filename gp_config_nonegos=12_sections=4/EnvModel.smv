                        angle_from_sec_2_to_sec_1 = 270 & connection_distance_sec_2_to_sec_1 = 17 : 26;
                        angle_from_sec_2_to_sec_1 = 270 & connection_distance_sec_2_to_sec_1 = 18 : 28;
                        angle_from_sec_2_to_sec_1 = 270 & connection_distance_sec_2_to_sec_1 = 19 : 29;
                        angle_from_sec_2_to_sec_1 = 270 & connection_distance_sec_2_to_sec_1 = 20 : 31;
                        angle_from_sec_2_to_sec_1 = 270 & connection_distance_sec_2_to_sec_1 = 21 : 32;
                        angle_from_sec_2_to_sec_1 = 270 & connection_distance_sec_2_to_sec_1 = 22 : 34;
                        angle_from_sec_2_to_sec_1 = 270 & connection_distance_sec_2_to_sec_1 = 23 : 35;
                        angle_from_sec_2_to_sec_1 = 270 & connection_distance_sec_2_to_sec_1 = 24 : 37;
                        angle_from_sec_2_to_sec_1 = 270 & connection_distance_sec_2_to_sec_1 = 25 : 38;
                        angle_from_sec_2_to_sec_1 = 270 & connection_distance_sec_2_to_sec_1 = 26 : 40;
                        angle_from_sec_2_to_sec_1 = 270 & connection_distance_sec_2_to_sec_1 = 27 : 42;
                        angle_from_sec_2_to_sec_1 = 270 & connection_distance_sec_2_to_sec_1 = 28 : 43;
                        angle_from_sec_2_to_sec_1 = 270 & connection_distance_sec_2_to_sec_1 = 29 : 45;
                        angle_from_sec_2_to_sec_1 = 270 & connection_distance_sec_2_to_sec_1 = 30 : 46;
                        
                     
                     TRUE : -1;
                  esac;
               
         
         DEFINE
               angle_from_sec_2_to_sec_3_raw := section_3.angle - section_2.angle;
               angle_from_sec_2_to_sec_3 := case
                  angle_from_sec_2_to_sec_3_raw < 0 : angle_from_sec_2_to_sec_3_raw + 360;
                  angle_from_sec_2_to_sec_3_raw >= 360 : angle_from_sec_2_to_sec_3_raw - 360;
                  TRUE : angle_from_sec_2_to_sec_3_raw;
               esac;
               connection_distance_sec_2_to_sec_3 := case -- TODO: We could have several connections for the same sections with different conn. distances.
                  outgoing_connection_0_of_section_2 = 3 : dist_0_of_section_2_to_3;
                  outgoing_connection_1_of_section_2 = 3 : dist_1_of_section_2_to_3;
                  
                  TRUE : -1;
               esac;

               arclength_from_sec_2_to_sec_3_on_lane_0 := case
                     angle_from_sec_2_to_sec_3 = 0 & connection_distance_sec_2_to_sec_3 = 10 : 20;
                        angle_from_sec_2_to_sec_3 = 0 & connection_distance_sec_2_to_sec_3 = 11 : 22;
