                        angle_from_sec_2_to_sec_3 = 90 & connection_distance_sec_2_to_sec_3 = 18 : 28;
                        angle_from_sec_2_to_sec_3 = 90 & connection_distance_sec_2_to_sec_3 = 19 : 29;
