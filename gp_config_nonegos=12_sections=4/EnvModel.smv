                     angle_from_sec_2_to_sec_3 = 90 & connection_distance_sec_2_to_sec_3 = 10 : 15;
                        angle_from_sec_2_to_sec_3 = 90 & connection_distance_sec_2_to_sec_3 = 11 : 17;
                        angle_from_sec_2_to_sec_3 = 90 & connection_distance_sec_2_to_sec_3 = 12 : 18;
                        angle_from_sec_2_to_sec_3 = 90 & connection_distance_sec_2_to_sec_3 = 13 : 20;
                        angle_from_sec_2_to_sec_3 = 90 & connection_distance_sec_2_to_sec_3 = 14 : 22;
                        angle_from_sec_2_to_sec_3 = 90 & connection_distance_sec_2_to_sec_3 = 15 : 23;
