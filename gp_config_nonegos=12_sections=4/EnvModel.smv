                        angle_from_sec_0_to_sec_2 = 270 & connection_distance_sec_0_to_sec_2 = 17 : 26;
                        angle_from_sec_0_to_sec_2 = 270 & connection_distance_sec_0_to_sec_2 = 18 : 28;
                        angle_from_sec_0_to_sec_2 = 270 & connection_distance_sec_0_to_sec_2 = 19 : 29;
                        angle_from_sec_0_to_sec_2 = 270 & connection_distance_sec_0_to_sec_2 = 20 : 31;
                        angle_from_sec_0_to_sec_2 = 270 & connection_distance_sec_0_to_sec_2 = 21 : 32;
                        angle_from_sec_0_to_sec_2 = 270 & connection_distance_sec_0_to_sec_2 = 22 : 34;
                        angle_from_sec_0_to_sec_2 = 270 & connection_distance_sec_0_to_sec_2 = 23 : 35;
                        angle_from_sec_0_to_sec_2 = 270 & connection_distance_sec_0_to_sec_2 = 24 : 37;
                        angle_from_sec_0_to_sec_2 = 270 & connection_distance_sec_0_to_sec_2 = 25 : 38;
                        angle_from_sec_0_to_sec_2 = 270 & connection_distance_sec_0_to_sec_2 = 26 : 40;
                        angle_from_sec_0_to_sec_2 = 270 & connection_distance_sec_0_to_sec_2 = 27 : 42;
                        angle_from_sec_0_to_sec_2 = 270 & connection_distance_sec_0_to_sec_2 = 28 : 43;
                        angle_from_sec_0_to_sec_2 = 270 & connection_distance_sec_0_to_sec_2 = 29 : 45;
                        angle_from_sec_0_to_sec_2 = 270 & connection_distance_sec_0_to_sec_2 = 30 : 46;
                        
                     
                     TRUE : -1;
                  esac;
               
         DEFINE
               angle_from_sec_0_to_sec_3_raw := section_3.angle - section_0.angle;
               angle_from_sec_0_to_sec_3 := case
                  angle_from_sec_0_to_sec_3_raw < 0 : angle_from_sec_0_to_sec_3_raw + 360;
                  angle_from_sec_0_to_sec_3_raw >= 360 : angle_from_sec_0_to_sec_3_raw - 360;
                  TRUE : angle_from_sec_0_to_sec_3_raw;
               esac;
               connection_distance_sec_0_to_sec_3 := case -- TODO: We could have several connections for the same sections with different conn. distances.
                  outgoing_connection_0_of_section_0 = 3 : dist_0_of_section_0_to_3;
                  outgoing_connection_1_of_section_0 = 3 : dist_1_of_section_0_to_3;
                  
                  TRUE : -1;
               esac;

               arclength_from_sec_0_to_sec_3_on_lane_0 := case
                     angle_from_sec_0_to_sec_3 = 0 & connection_distance_sec_0_to_sec_3 = 10 : 20;
                        angle_from_sec_0_to_sec_3 = 0 & connection_distance_sec_0_to_sec_3 = 11 : 22;
