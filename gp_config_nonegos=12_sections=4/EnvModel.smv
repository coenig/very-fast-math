                        angle_from_sec_2_to_sec_3 = 270 & connection_distance_sec_2_to_sec_3 = 14 : 22;
                        angle_from_sec_2_to_sec_3 = 270 & connection_distance_sec_2_to_sec_3 = 15 : 23;
