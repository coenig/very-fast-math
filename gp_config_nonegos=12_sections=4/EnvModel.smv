                        angle_from_sec_0_to_sec_1 = 180 & connection_distance_sec_0_to_sec_1 = 24 : 0;
                        angle_from_sec_0_to_sec_1 = 180 & connection_distance_sec_0_to_sec_1 = 25 : 0;
                        angle_from_sec_0_to_sec_1 = 180 & connection_distance_sec_0_to_sec_1 = 26 : 0;
