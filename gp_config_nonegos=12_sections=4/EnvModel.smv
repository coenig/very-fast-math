                        angle_from_sec_2_to_sec_1 = 270 & connection_distance_sec_2_to_sec_1 = 13 : 20;
                        angle_from_sec_2_to_sec_1 = 270 & connection_distance_sec_2_to_sec_1 = 14 : 22;
                        angle_from_sec_2_to_sec_1 = 270 & connection_distance_sec_2_to_sec_1 = 15 : 23;
